#!/usr/bin/env bash
set -euo pipefail

box_log() { printf '%s\n' "$*"; }
box_fail() { printf 'Box installer bootstrap failed: %s\n' "$*" >&2; exit 1; }
box_warn() { printf 'Box installer bootstrap warning: %s\n' "$*" >&2; }

DEFAULT_PUBLIC_RELEASE_ROOT="https://citadel.box/releases/box"
TRUSTED_RELEASE_PUBLIC_KEYS_BASE64=""

if [ "${BASH_VERSION:-}" = "" ]; then
  box_fail "bash is required."
fi

box_bootstrap_usage() {
  cat <<'EOF'
Usage:
  curl -fsSL https://citadel.box/install | bash
  curl -fsSL https://citadel.box/install | bash -s -- [options]

Installs Box for macOS from the public stable release channel, provisions local
HTTPS routing, and verifies https://app.citadel.localhost before reporting
success.

Options:
  --channel stable             Public release channel, default stable.
  --version                    Print the public release version and exit.
  --doctor                     Check installer prerequisites and exit.
  --uninstall                  Stop Box and remove local-edge provisioning.
  --no-open                    Do not open the app after install.
  --verbose                    Print command diagnostics when a phase fails.
  --help, -h                   Show this help.

Operator-only private beta inputs:
  BOX_INSTALL_MANIFEST_URL     Fetch a signed private beta manifest.
  BOX_INSTALL_SOURCE_URL       Deprecated checksum-less private beta fallback.
EOF
}

box_has_help_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --help | -h)
        return 0
        ;;
    esac
  done
  return 1
}

box_has_version_arg() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --version)
        return 0
        ;;
    esac
  done
  return 1
}

if box_has_help_arg "$@"; then
  box_bootstrap_usage
  exit 0
fi

case "$(uname -s)" in
  Darwin) ;;
  *) box_fail "Box installer currently supports macOS." ;;
esac

case "$(uname -m)" in
  arm64) ;;
  *) box_fail "Box installer currently supports Apple Silicon Macs." ;;
esac

if ! command -v bun >/dev/null 2>&1; then
  box_log "Installing Bun runtime..."
  curl -fsSL https://bun.sh/install | bash
  export PATH="$HOME/.bun/bin:$PATH"
fi

box_manifest_value() {
  local manifest_path="$1"
  local field="$2"
  local base_url="$3"
  BOX_INSTALL_MANIFEST_PATH="$manifest_path" \
    BOX_INSTALL_MANIFEST_FIELD="$field" \
    BOX_INSTALL_MANIFEST_BASE_URL="$base_url" \
    bun --eval '
const manifestPath = process.env.BOX_INSTALL_MANIFEST_PATH;
const field = process.env.BOX_INSTALL_MANIFEST_FIELD;
const baseUrl = process.env.BOX_INSTALL_MANIFEST_BASE_URL ?? "";
const raw = await Bun.file(manifestPath).text();
const manifest = JSON.parse(raw);
const artifact =
  manifest.artifact ??
  manifest.artifacts?.macosArm64 ??
  manifest.artifacts?.["macos-arm64"] ??
  manifest.artifacts?.darwinArm64 ??
  manifest.artifacts?.["darwin-arm64"] ??
  manifest.artifacts?.box;
let value;
if (field === "artifactUrl") {
  value = manifest.artifactUrl ?? artifact?.url;
} else if (field === "version") {
  value = manifest.version ?? manifest.releaseVersion ?? artifact?.version;
} else {
  value =
    manifest.artifactSha256 ??
    manifest.sha256 ??
    artifact?.sha256 ??
    artifact?.sha256Digest;
}
if (typeof value !== "string" || value.trim() === "") {
  process.exit(0);
}
value = value.trim();
if (field === "artifactUrl" && baseUrl !== "") {
  value = new URL(value, baseUrl).href;
}
process.stdout.write(value);
'
}

box_manifest_signature_status() {
  local manifest_path="$1"
  BOX_INSTALL_MANIFEST_PATH="$manifest_path" \
    BOX_RELEASE_TRUSTED_PUBLIC_KEYS_BASE64="$TRUSTED_RELEASE_PUBLIC_KEYS_BASE64" \
    bun --eval '
import { createVerify } from "node:crypto";

const manifestPath = process.env.BOX_INSTALL_MANIFEST_PATH;
const trustedKeyValues = (process.env.BOX_RELEASE_TRUSTED_PUBLIC_KEYS_BASE64 ?? "")
  .split(/\s+/)
  .map((value) => value.trim())
  .filter(Boolean);
const raw = await Bun.file(manifestPath).text();
const manifest = JSON.parse(raw);
const signature = manifest.signature;

function normalize(value) {
  if (Array.isArray(value)) return value.map(normalize);
  if (value && typeof value === "object") {
    return Object.fromEntries(
      Object.keys(value)
        .sort()
        .map((key) => [key, normalize(value[key])]),
    );
  }
  return value;
}

if (!signature || typeof signature !== "object") {
  process.stdout.write("missing");
  process.exit(0);
}
if (trustedKeyValues.length === 0) {
  process.stdout.write("trusted-key-missing");
  process.exit(0);
}
if (signature.algorithm !== "rsa-sha256") {
  process.stdout.write("unsupported-algorithm");
  process.exit(0);
}
if (
  typeof signature.value !== "string" ||
  signature.value.trim() === ""
) {
  process.stdout.write("malformed");
  process.exit(0);
}

const signedManifest = { ...manifest };
delete signedManifest.signature;
const payload = JSON.stringify(normalize(signedManifest));
let malformedTrustedKey = false;
for (const trustedKeyValue of trustedKeyValues) {
  let publicKeyPem;
  try {
    publicKeyPem = Buffer.from(trustedKeyValue, "base64").toString("utf8");
  } catch {
    malformedTrustedKey = true;
    continue;
  }
  if (!publicKeyPem.includes("BEGIN PUBLIC KEY")) {
    malformedTrustedKey = true;
    continue;
  }
  try {
    const verifier = createVerify("sha256");
    verifier.update(payload);
    verifier.end();
    if (verifier.verify(publicKeyPem, signature.value, "base64")) {
      process.stdout.write("ok");
      process.exit(0);
    }
  } catch {
    malformedTrustedKey = true;
  }
}
process.stdout.write(malformedTrustedKey ? "trusted-key-malformed" : "invalid");
'
}

box_manifest_public_distribution_status() {
  local manifest_path="$1"
  BOX_INSTALL_MANIFEST_PATH="$manifest_path" \
    bun --eval '
const manifestPath = process.env.BOX_INSTALL_MANIFEST_PATH;
const raw = await Bun.file(manifestPath).text();
const manifest = JSON.parse(raw);
const distribution = manifest.appleDistribution;

function hasShaEvidence(value) {
  return (
    value &&
    typeof value === "object" &&
    typeof value.file === "string" &&
    value.file.trim() !== "" &&
    typeof value.sha256 === "string" &&
    /^[0-9a-f]{64}$/i.test(value.sha256.trim())
  );
}

if (!distribution || typeof distribution !== "object") {
  process.stdout.write("missing");
  process.exit(0);
}
if (distribution.developerIdSigned !== true) {
  process.stdout.write("developer-id-missing");
  process.exit(0);
}
if (distribution.notarized !== true) {
  process.stdout.write("notarization-missing");
  process.exit(0);
}
if (!hasShaEvidence(distribution.evidence?.developerId)) {
  process.stdout.write("developer-id-evidence-missing");
  process.exit(0);
}
if (!hasShaEvidence(distribution.evidence?.notarization)) {
  process.stdout.write("notarization-evidence-missing");
  process.exit(0);
}
process.stdout.write("ok");
'
}

box_sha256() {
  shasum -a 256 "$1" | awk '{print tolower($1)}'
}

box_public_channel() {
  local channel="stable"
  local expect_channel_value=0
  local arg
  for arg in "$@"; do
    if [ "$expect_channel_value" = "1" ]; then
      channel="$arg"
      expect_channel_value=0
      continue
    fi
    case "$arg" in
      --channel)
        expect_channel_value=1
        ;;
      --channel=*)
        channel="${arg#--channel=}"
        ;;
    esac
  done

  if [ "$expect_channel_value" = "1" ]; then
    box_fail "--channel requires a value."
  fi

  case "$channel" in
    stable)
      printf '%s' "$channel"
      ;;
    private-beta)
      box_fail "public bootstrap only supports --channel stable. Use BOX_INSTALL_MANIFEST_URL for operator private-beta testing."
      ;;
    *)
      box_fail "--channel must be stable or private-beta."
      ;;
  esac
}

box_public_manifest_url() {
  local channel="$1"
  printf '%s/%s/manifest.json' "$DEFAULT_PUBLIC_RELEASE_ROOT" "$channel"
}

box_safe_path_segment() {
  local value="$1"
  case "$value" in
    "" | *"/"* | *".."* | *[!A-Za-z0-9._-]*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

box_data_home() {
  local data_home="${XDG_DATA_HOME:-}"
  case "$data_home" in
    /*)
      printf '%s' "$data_home"
      ;;
    *)
      printf '%s/.local/share' "$HOME"
      ;;
  esac
}

box_materialize_public_bundle() {
  local source_root="$1"
  local release_version="$2"
  box_safe_path_segment "$release_version" || box_fail "release manifest version is not a safe install path segment."

  local app_root
  local release_root
  local next_root
  local current_link
  app_root="$(box_data_home)/citadel/localhost/app/box"
  release_root="$app_root/releases/$release_version"
  next_root="$release_root.next"
  current_link="$app_root/current"

  mkdir -p "$(dirname "$release_root")"
  rm -rf "$next_root"
  ditto "$source_root" "$next_root"
  rm -rf "$release_root"
  mv "$next_root" "$release_root"
  rm -rf "$current_link"
  ln -s "$release_root" "$current_link"
  printf '%s' "$current_link"
}

SCRIPT_PATH="${BASH_SOURCE[0]:-}"
if [ -n "$SCRIPT_PATH" ] && [ -f "$SCRIPT_PATH" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
else
  SCRIPT_DIR=""
fi

if [ -n "$SCRIPT_DIR" ] && [ -f "$SCRIPT_DIR/box_install.mjs" ]; then
  REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  MANIFEST_URL="${BOX_INSTALL_MANIFEST_URL:-}"
  SOURCE_URL="${BOX_INSTALL_SOURCE_URL:-}"
  PUBLIC_INSTALL=0
  WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/box-install.XXXXXX")"
  trap 'rm -rf "$WORK_DIR"' EXIT

  if [ -z "$MANIFEST_URL" ] && [ -z "$SOURCE_URL" ]; then
    PUBLIC_CHANNEL="$(box_public_channel "$@")"
    MANIFEST_URL="$(box_public_manifest_url "$PUBLIC_CHANNEL")"
    PUBLIC_INSTALL=1
  fi

  if [ -n "$MANIFEST_URL" ]; then
    box_log "Downloading Box release manifest..."
    curl -fsSL "$MANIFEST_URL" -o "$WORK_DIR/box-release-manifest.json"
    SIGNATURE_STATUS="$(box_manifest_signature_status "$WORK_DIR/box-release-manifest.json")"
    case "$SIGNATURE_STATUS" in
      ok)
        box_log "Verified Box release manifest signature."
        ;;
      missing)
        if [ "$PUBLIC_INSTALL" = "1" ]; then
          box_fail "release manifest signature is required for public installs."
        fi
        box_warn "release manifest is unsigned; checksum-only private-beta verification in use."
        ;;
      *)
        box_fail "release manifest signature verification failed: $SIGNATURE_STATUS."
        ;;
    esac
    if [ "$PUBLIC_INSTALL" = "1" ]; then
      APPLE_DISTRIBUTION_STATUS="$(box_manifest_public_distribution_status "$WORK_DIR/box-release-manifest.json")"
      case "$APPLE_DISTRIBUTION_STATUS" in
        ok)
          box_log "Verified Apple distribution evidence in release manifest."
          ;;
        *)
          box_fail "Apple Developer ID signing and notarization evidence is required for public installs: $APPLE_DISTRIBUTION_STATUS."
          ;;
      esac
      RELEASE_VERSION="$(box_manifest_value "$WORK_DIR/box-release-manifest.json" "version" "$MANIFEST_URL")"
      [ -n "$RELEASE_VERSION" ] || box_fail "release manifest is missing version."
      if box_has_version_arg "$@"; then
        box_log "$RELEASE_VERSION"
        exit 0
      fi
    fi
    ARTIFACT_URL="$(box_manifest_value "$WORK_DIR/box-release-manifest.json" "artifactUrl" "$MANIFEST_URL")"
    ARTIFACT_SHA256="$(box_manifest_value "$WORK_DIR/box-release-manifest.json" "artifactSha256" "$MANIFEST_URL")"
    [ -n "$ARTIFACT_URL" ] || box_fail "release manifest is missing artifactUrl."
    [ -n "$ARTIFACT_SHA256" ] || box_fail "release manifest is missing artifactSha256."
    box_log "Downloading Box installer bundle..."
    curl -fsSL "$ARTIFACT_URL" -o "$WORK_DIR/box.tar.gz"
    ACTUAL_SHA256="$(box_sha256 "$WORK_DIR/box.tar.gz")"
    EXPECTED_SHA256="$(printf '%s' "$ARTIFACT_SHA256" | tr '[:upper:]' '[:lower:]')"
    if [ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]; then
      box_fail "release artifact checksum mismatch."
    fi
    box_log "Verified Box installer bundle checksum."
  elif [ -n "$SOURCE_URL" ]; then
    box_warn "BOX_INSTALL_SOURCE_URL is a private-beta fallback; prefer BOX_INSTALL_MANIFEST_URL with checksum verification."
    box_log "Downloading Box installer bundle..."
    curl -fsSL "$SOURCE_URL" -o "$WORK_DIR/box.tar.gz"
  fi

  tar -xzf "$WORK_DIR/box.tar.gz" -C "$WORK_DIR"
  REPO_ROOT="$(find "$WORK_DIR" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  [ -n "$REPO_ROOT" ] || box_fail "Unable to locate extracted Box installer bundle."
  if [ "${PUBLIC_INSTALL:-0}" = "1" ]; then
    box_log "Installing Box release into the local app directory..."
    REPO_ROOT="$(box_materialize_public_bundle "$REPO_ROOT" "$RELEASE_VERSION")"
  fi
fi

cd "$REPO_ROOT"
if [ "${PUBLIC_INSTALL:-0}" = "1" ]; then
  env \
    -u BOX_INSTALL_CHANNEL \
    -u BOX_INSTALL_MANIFEST_URL \
    -u BOX_INSTALL_SOURCE_URL \
    -u BOX_KIT_REGISTRY_URL \
    -u BOX_KIT_REGISTRY_TOKEN \
    bun run ./scripts/box_install.mjs --public "$@"
  exit $?
fi
exec bun run ./scripts/box_install.mjs "$@"
